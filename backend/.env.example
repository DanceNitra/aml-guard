# === AML Guard Backend — Produkčná konfigurácia ===
# Kopíruj ako .env a vyplň hodnoty
#
# Pre Render: tieto hodnoty nastav cez Dashboard > Environment Variables
# Netlač .env do git-u! Render používa generateValue pre SECRET_KEY.

# === App ===
APP_NAME=AML Guard API
APP_VERSION=1.0.0
DEBUG=false

# === Database ===
# Lokálne (SQLite — len na testovanie):
#   DATABASE_URL=sqlite+aiosqlite:///./data/aml_guard.db
# Produkcia (PostgreSQL — Render paid tier):
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/amlguard
DATABASE_URL=sqlite+aiosqlite:///./data/aml_guard.db

# === Auth ===
# Vygeneruj cez: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Stripe ===
# Nechaj prázdne pre demo režim (billing endpointy vrátia 400)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === CORS ===
# Povolené domény (čiarkou oddelené)
CORS_ORIGINS=http://localhost:8000,https://dancenitra.github.io,https://aml-guard.onrender.com

# === Admin ===
# API kľúč pre profesijné komory (voliteľné)
ADMIN_API_KEY=
